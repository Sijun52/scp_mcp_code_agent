# ============================================================
# SCP MCP Code Agent - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ------ LLM Provider ------
# OpenAI API key (required)
OPENAI_API_KEY=your-openai-api-key-here

# OpenAI model to use for code generation
LLM_MODEL=gpt-4o

# LLM temperature (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.2

# ------ OpenAPI MCP Server ------
# Connection config for the OpenAPI spec MCP server (assumed to exist)
OPENAPI_MCP_TRANSPORT=stdio
# If stdio transport:
OPENAPI_MCP_COMMAND=python
OPENAPI_MCP_ARGS=-m openapi_mcp_server
# If SSE/HTTP transport:
# OPENAPI_MCP_URL=http://localhost:8080/mcp

# Credentials for the target cloud platform API
CLOUD_API_BASE_URL=https://api.example.com
CLOUD_API_KEY=your-cloud-api-key-here
CLOUD_TENANT_ID=your-tenant-id-here

# ------ File System ------
# Root directory where generated MCP servers will be written
OUTPUT_DIR=./generated

# Path to the MCP code example directory (used as template reference)
EXAMPLE_DIR=./mcp_code_example

# ------ Chainlit ------
# Chainlit server settings
CHAINLIT_HOST=0.0.0.0
CHAINLIT_PORT=8000

# ------ Agent Settings ------
# Maximum iterations the agent can take before giving up
AGENT_MAX_ITERATIONS=25

# Verbose logging for LangChain agent
AGENT_VERBOSE=true
