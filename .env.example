# ============================================================
# SCP MCP Code Agent - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ------ LLM Provider ------
# OpenAI API key (필수)
OPENAI_API_KEY=your-openai-api-key-here

# 사용할 모델 (기본값: gpt-4o)
LLM_MODEL=gpt-4o

# ------ OpenAPI MCP Server (Remote HTTP, 인증 불필요) ------
OPENAPI_MCP_TRANSPORT=streamable_http
OPENAPI_MCP_URL=http://your-openapi-mcp-server:8080/mcp

# 로컬 개발 환경에서 stdio 방식 사용 시:
# OPENAPI_MCP_TRANSPORT=stdio
# OPENAPI_MCP_COMMAND=python
# OPENAPI_MCP_ARGS=-m openapi_mcp_server

# ------ SCP Docs MCP Server (선택) ------
# 미설정 시 docs 연결 없이 동작 (에이전트가 스펙만으로 프롬프트 작성)
DOCS_MCP_URL=http://your-docs-mcp-server:8080/mcp

# ------ File System ------
# 생성된 MCP 서버 저장 위치 (기본값: 사용자 홈 디렉토리 ~/scp-mcp-servers)
# 대화 중 "경로를 X로 변경해줘" 로도 변경 가능
# OUTPUT_DIR=/custom/path

# ------ Agent Settings ------
# LangChain 에이전트 상세 로깅
AGENT_VERBOSE=true