# ============================================================
# SCP MCP Code Agent - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ------ LLM Provider ------
# OpenAI API key (필수)
OPENAI_API_KEY=your-openai-api-key-here

# 사용할 모델 (기본값: gpt-4o)
LLM_MODEL=gpt-4o

# LLM temperature (0.0 = 결정적, 1.0 = 창의적)
LLM_TEMPERATURE=0.2

# ------ OpenAPI MCP Server (Remote HTTP) ------
# Docker 환경에서는 Remote HTTP 방식으로 연결
OPENAPI_MCP_TRANSPORT=streamable_http
OPENAPI_MCP_URL=http://your-openapi-mcp-server:8080/mcp

# 로컬 개발 환경에서 stdio 방식 사용 시:
# OPENAPI_MCP_TRANSPORT=stdio
# OPENAPI_MCP_COMMAND=python
# OPENAPI_MCP_ARGS=-m openapi_mcp_server

# ------ Cloud Platform Credentials ------
# OpenAPI MCP 서버로 전달될 SCP 플랫폼 인증 정보
CLOUD_API_BASE_URL=https://api.example.com
CLOUD_API_KEY=your-cloud-api-key-here
CLOUD_TENANT_ID=your-tenant-id-here

# ------ File System ------
# 생성된 MCP 서버가 저장될 디렉토리
# Docker: 컨테이너 내부 경로 (volume mount로 로컬과 연결됨)
OUTPUT_DIR=/app/generated
# 로컬 개발 시:
# OUTPUT_DIR=./generated

# 에이전트가 참조할 예시 코드 디렉토리
EXAMPLE_DIR=/app/mcp_code_example
# 로컬 개발 시:
# EXAMPLE_DIR=./mcp_code_example

# ------ Agent Settings ------
# 에이전트 최대 반복 횟수
AGENT_MAX_ITERATIONS=25

# LangChain 에이전트 상세 로깅
AGENT_VERBOSE=true